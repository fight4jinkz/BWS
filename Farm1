--[[
    Background Logic / Automation Functions
]]

local function tweenTo(targetCFrame)
    if not LocalPlayer.Character or not LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then return end
    local hrp = LocalPlayer.Character.HumanoidRootPart
    local distance = (hrp.Position - targetCFrame.Position).Magnitude
    local timeToTake = distance / Flags.TweenSpeed
    
    local ti = TweenInfo.new(timeToTake, Enum.EasingStyle.Linear)
    local tween = TweenService:Create(hrp, ti, {CFrame = targetCFrame})
    tween:Play()
    tween.Completed:Wait()
end

local function getMyHive()
    if not workspace:FindFirstChild("Hives") then return nil end
    for _, hive in ipairs(workspace.Hives:GetChildren()) do
        if hive:FindFirstChild("Platform") and hive.Platform:FindFirstChild("Top") and hive.Platform.Top:FindFirstChild("Username") then
            local userText = hive.Platform.Top.Username:FindFirstChild("User")
            if userText and userText.Text == LocalPlayer.Name then
                return hive
            end
        end
    end
    return nil
end

local function convertPollen()
    local hive = getMyHive()
    if not hive then return end
    
    isConverting = true
    tweenTo(hive.Platform.Top.CFrame)
    task.wait(0.5)
    
    while Flags.AutoFarm and LocalPlayer:FindFirstChild("Pollen") and LocalPlayer.Pollen.Value > 0 do
        VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.E, false, game)
        task.wait(0.1)
        VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.E, false, game)
        task.wait(3)
    end
    isConverting = false
end

local function getClosestToken(originPos)
    local closestToken = nil
    local shortestDist = Flags.TokenRange
    
    if workspace:FindFirstChild("Debris") and workspace.Debris:FindFirstChild("Tokens") then
        for _, tokenFolder in ipairs(workspace.Debris.Tokens:GetChildren()) do
            -- The folder/model itself is named after the player
            if tokenFolder.Name == LocalPlayer.Name or string.find(tokenFolder.Name, LocalPlayer.Name) then
                -- Inside that folder is the actual "Token" part/model
                local actualToken = tokenFolder:FindFirstChild("Token")
                if actualToken then
                    local tPos = actualToken:IsA("Model") and actualToken:GetPivot().Position or actualToken.Position
                    local dist = (tPos - originPos).Magnitude
                    if dist <= shortestDist then
                        shortestDist = dist
                        closestToken = tPos
                    end
                end
            end
        end
    end
    return closestToken
end

-- Main Auto Farm & Movement Loop
task.spawn(function()
    while task.wait(0.15) do
        if Flags.AutoFarm and LocalPlayer.Character and LocalPlayer:FindFirstChild("Pollen") and LocalPlayer:FindFirstChild("Cap") then
            
            -- HIVE CLAIM CHECK
            if not getMyHive() then
                -- We don't have a hive, find an empty one
                if workspace:FindFirstChild("Hives") then
                    for _, hive in ipairs(workspace.Hives:GetChildren()) do
                        if hive:FindFirstChild("Claimed") and hive.Claimed.Value == false then
                            if hive:FindFirstChild("Platform") and hive.Platform:FindFirstChild("Top") then
                                tweenTo(hive.Platform.Top.CFrame)
                                task.wait(0.5)
                                VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.E, false, game)
                                task.wait(0.1)
                                VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.E, false, game)
                                task.wait(1.5)
                                break -- Break out of the for-loop so the main loop can restart and confirm we own it
                            end
                        end
                    end
                end
                continue -- Skip the rest of the farming loop until a hive is properly secured
            end

            local hrp = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
            local humanoid = LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
            
            if not hrp or not humanoid then continue end
            
            -- Apply WalkSpeed
            humanoid.WalkSpeed = Flags.WalkSpeed
            
            local currentPollen = LocalPlayer.Pollen.Value
            local maxPollen = LocalPlayer.Cap.Value
            local currentPercent = (currentPollen / maxPollen) * 100
            
            if currentPercent >= Flags.ConvertPercent then
                convertPollen()
            elseif not isConverting and Flags.SelectedField then
                local fieldBox = workspace.Fields:FindFirstChild(Flags.SelectedField)
                if fieldBox and fieldBox:FindFirstChild("FieldBox") then
                    local fieldCenter = fieldBox.FieldBox.Position
                    local distToCenter = (hrp.Position - fieldCenter).Magnitude
                    
                    -- Tween back to center if we wander out of the Farming Radius bounds
                    if distToCenter > Flags.FarmingRadius then
                        tweenTo(fieldBox.FieldBox.CFrame)
                        continue
                    end
                    
                    -- Check for Tokens first
                    local tokenPos = nil
                    if Flags.AutoToken then
                        tokenPos = getClosestToken(hrp.Position)
                    end
                    
                    if tokenPos then
                        -- Walk to token
                        humanoid:MoveTo(tokenPos)
                    else
                        -- Walk in a circle around the field
                        walkAngle = walkAngle + math.rad(30)
                        if walkAngle >= math.pi * 2 then walkAngle = 0 end
                        
                        local walkRadius = Flags.FarmingRadius * 0.65 
                        
                        local targetCirclePos = fieldCenter + Vector3.new(
                            math.cos(walkAngle) * walkRadius, 
                            0, 
                            math.sin(walkAngle) * walkRadius
                        )
                        humanoid:MoveTo(targetCirclePos)
                    end
                end
            end
        end
    end
end)

-- Auto Dig Loop
task.spawn(function()
    while true do
        if Flags.AutoDig and LocalPlayer.Character then
            if Flags.UseVIMClick then
                -- Simulates Left Mouse Button Click globally
                VirtualInputManager:SendMouseButtonEvent(0, 0, 0, true, game, 1)
                task.wait(0.05)
                VirtualInputManager:SendMouseButtonEvent(0, 0, 0, false, game, 1)
            else
                -- Traditional Remote Fire
                local tool = LocalPlayer.Character:FindFirstChildOfClass("Tool")
                if tool and tool:FindFirstChild("ToolRemote") then
                    tool.ToolRemote:FireServer()
                end
            end
        end
        task.wait(Flags.DigCooldown)
    end
end)
